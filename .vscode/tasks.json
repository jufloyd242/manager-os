{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Manager OS: 01 Backend Compile",
      "type": "shell",
      "command": "python -m compileall src/manager_os",
      "group": "build",
      "problemMatcher": [],
      "presentation": { "showReuseMessage": false, "clear": true }
    },
    {
      "label": "Manager OS: 02 Backend Targeted Tests",
      "type": "shell",
      "command": "python -m pytest tests/test_api_deals.py tests/test_api_forecast.py tests/test_api_workspace_context.py tests/test_api_meetings.py tests/test_api_health.py tests/test_api_status.py -q -x --tb=short",
      "group": "test",
      "problemMatcher": [],
      "presentation": { "showReuseMessage": false, "clear": true }
    },
    {
      "label": "Manager OS: 03 Backend Full Tests",
      "type": "shell",
      "command": "python -m pytest tests/ -q --tb=short",
      "group": "test",
      "problemMatcher": [],
      "presentation": { "showReuseMessage": false, "clear": true }
    },
    {
      "label": "Manager OS: 04 Backend Ruff",
      "type": "shell",
      "command": "python -m ruff check src/",
      "group": "test",
      "problemMatcher": [],
      "presentation": { "showReuseMessage": false, "clear": true }
    },
    {
      "label": "Manager OS: 05 Backend Pyright",
