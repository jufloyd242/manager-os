# Required paths
MANAGER_OS_VAULT_PATH=/path/to/your/obsidian/vault
MANAGER_OS_DB_PATH=./data/processed/manager_os.duckdb
MANAGER_OS_FORECAST_CSV=./data/raw/forecast.csv
MANAGER_OS_DEALS_CSV=./data/raw/deals.csv
MANAGER_OS_WORKSPACE_SUMMARY_DIR=./data/raw/summaries

# Optional config / snapshot paths
MANAGER_OS_CONFIG_DIR=./config
MANAGER_OS_GWS_SNAPSHOT_DIR=./data/raw/gws_snapshots

# Gemini model compatibility setting (if needed)
MANAGER_OS_GEMINI_MODEL=gemini-2.0-flash

# Gemini CLI / LLM extraction
MANAGER_OS_LLM_ENABLED=true
MANAGER_OS_LLM_PROVIDER=gemini_cli
MANAGER_OS_GEMINI_CLI_BIN=gemini
MANAGER_OS_GEMINI_CLI_MODEL=gemini-2.0-flash
MANAGER_OS_GEMINI_CLI_TIMEOUT_SECONDS=120
MANAGER_OS_GEMINI_CLI_WORKDIR=
MANAGER_OS_GEMINI_CLI_ARGS=
MANAGER_OS_GEMINI_CLI_YOLO=false
MANAGER_OS_GEMINI_CLI_YOLO_ARGS=-y
MANAGER_OS_LLM_MAX_CANDIDATES=25
MANAGER_OS_LLM_MAX_CHARS_PER_NOTE=6000

# Vertex AI / Gemini CLI auth (required when using Vertex AI backend)
# Run: gcloud auth application-default login
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=global
GOOGLE_GENAI_USE_VERTEXAI=true

# Optional: vault write-back path (Phase 7, read-only until explicitly set)
# MANAGER_OS_VAULT_WRITE_PATH=/path/to/your/obsidian/vault/manager-os-output

# Workspace retrieval through Gemini CLI (read-only, YOLO mode)
MANAGER_OS_WORKSPACE_RETRIEVAL_ENABLED=false
MANAGER_OS_WORKSPACE_RETRIEVAL_PROVIDER=gemini_cli
MANAGER_OS_WORKSPACE_RETRIEVAL_YOLO=true

# Workspace source toggles
MANAGER_OS_RETRIEVE_FORECAST_WITH_GEMINI=true
MANAGER_OS_RETRIEVE_CALENDAR_WITH_GEMINI=true
MANAGER_OS_RETRIEVE_WORKSPACE_ACTIVITY_WITH_GEMINI=true

# Workspace activity source configuration
# Source of truth for workspace activity summary (read-only)
MANAGER_OS_WORKSPACE_ACTIVITY_SOURCE=google_chat_space
MANAGER_OS_WORKSPACE_ACTIVITY_CHAT_URL=https://chat.google.com/u/0/app/chat/AAQA61WgdSs
# Chat space resource ID used in MCP tool calls (from space URL)
MANAGER_OS_CHAT_SPACE_ID=AAQA61WgdSs
MANAGER_OS_WORKSPACE_ACTIVITY_LOOKBACK_DAYS=1

# Forecast source configuration
MANAGER_OS_FORECAST_QUERY="Find the latest people/staffing forecast for AI ML team and export the usable tabular data as CSV-like JSON."

# Explicit Google Sheet forecast source via Gemini CLI (Deterministic)
# Exact source is mandatory. No local CSV or broad search fallbacks are allowed.
MANAGER_OS_FORECAST_SOURCE=google_sheet_gemini
MANAGER_OS_FORECAST_SHEET_URL=https://docs.google.com/spreadsheets/d/1reTpjZN89MIvhU5RBfaVnM1SC0vfRcg37XBCKohyMcg/edit?gid=126839721#gid=126839721
MANAGER_OS_FORECAST_SHEET_ID=1reTpjZN89MIvhU5RBfaVnM1SC0vfRcg37XBCKohyMcg
MANAGER_OS_FORECAST_SHEET_GID=126839721
MANAGER_OS_FORECAST_EXPORT_URL=https://docs.google.com/spreadsheets/d/1reTpjZN89MIvhU5RBfaVnM1SC0vfRcg37XBCKohyMcg/export?format=csv&gid=126839721

# Output path for the retrieved forecast CSV (written by forecast-fetch)
MANAGER_OS_FORECAST_LOCAL_CSV=/Users/jufloyd/Google Drive/Other computers/My MacBook Pro/obsidian/insight/work/imports/forecast.csv

MANAGER_OS_FORECAST_DOWNLOAD_TIMEOUT_SECONDS=120
MANAGER_OS_FORECAST_STALE_AFTER_HOURS=24

# Project index source configuration
# Source of truth for historical project/deal knowledge
MANAGER_OS_PROJECT_INDEX_SOURCE=google_sheet_gemini
MANAGER_OS_PROJECT_INDEX_SHEET_URL=https://docs.google.com/spreadsheets/d/1qoxa7kh5UPs8yCs6UIAbR9_n_odnYl1lByJi4F85P5A/edit?gid=326551622#gid=326551622
MANAGER_OS_PROJECT_INDEX_SHEET_ID=1qoxa7kh5UPs8yCs6UIAbR9_n_odnYl1lByJi4F85P5A
MANAGER_OS_PROJECT_INDEX_SHEET_GID=326551622
MANAGER_OS_PROJECT_INDEX_EXPORT_URL=https://docs.google.com/spreadsheets/d/1qoxa7kh5UPs8yCs6UIAbR9_n_odnYl1lByJi4F85P5A/export?format=csv&gid=326551622
MANAGER_OS_PROJECT_INDEX_LOCAL_CSV=./data/raw/project_index.csv
MANAGER_OS_PROJECT_INDEX_DOWNLOAD_TIMEOUT_SECONDS=180
MANAGER_OS_PROJECT_INDEX_STALE_AFTER_HOURS=24
MANAGER_OS_PROJECT_INDEX_REQUIRE_EXACT_SOURCE=true
MANAGER_OS_PROJECT_DOC_SEARCH_ENABLED=true
MANAGER_OS_PROJECT_DOC_SEARCH_LIMIT_PER_PROJECT=10

# Calendar retrieval configuration
MANAGER_OS_CALENDAR_LOOKAHEAD_DAYS=2
MANAGER_OS_CALENDAR_LOOKBACK_DAYS=1
