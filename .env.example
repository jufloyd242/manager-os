# Required paths
MANAGER_OS_VAULT_PATH=/path/to/your/obsidian/vault
MANAGER_OS_DB_PATH=./data/processed/manager_os.duckdb
MANAGER_OS_FORECAST_CSV=./data/raw/forecast.csv
MANAGER_OS_DEALS_CSV=./data/raw/deals.csv
MANAGER_OS_WORKSPACE_SUMMARY_DIR=./data/raw/summaries

# Optional: override config directory (default: ./config)
# MANAGER_OS_CONFIG_DIR=./config

# LLM extraction (Gemini CLI provider)
MANAGER_OS_LLM_ENABLED=true
MANAGER_OS_LLM_PROVIDER=gemini_cli
MANAGER_OS_GEMINI_CLI_BIN=gemini
MANAGER_OS_GEMINI_CLI_MODEL=gemini-2.0-flash
MANAGER_OS_GEMINI_CLI_TIMEOUT_SECONDS=120
MANAGER_OS_GEMINI_CLI_WORKDIR=
MANAGER_OS_LLM_MAX_CANDIDATES=25
MANAGER_OS_LLM_MAX_CHARS_PER_NOTE=6000

# Optional Gemini CLI / Vertex auth context
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1
GOOGLE_GENAI_USE_VERTEXAI=true

# Optional: vault write-back path (Phase 7, read-only until explicitly set)
# MANAGER_OS_VAULT_WRITE_PATH=/path/to/your/obsidian/vault/manager-os-output
